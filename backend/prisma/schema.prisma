generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  system_owner
  platform_admin
  channel_owner
  channel_admin
  channel_moderator
  viewer
}

enum Platform {
  twitch
  discord
}

model User {
  id           String          @id @default(cuid())
  email        String?         @unique
  passwordHash String?
  twitchUserId String?         @unique
  twitchLogin  String?
  displayName  String
  avatarUrl    String?
  isLocalAdmin Boolean         @default(false)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  members      ChannelMember[]
  logs         AuditLog[]      @relation("AuditUser")
}

model Channel {
  id                String              @id @default(cuid())
  twitchChannelId   String              @unique
  twitchLogin       String
  displayName       String
  avatarUrl         String?
  isActive          Boolean             @default(true)
  botEnabled        Boolean             @default(true)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  members           ChannelMember[]
  settings          ChannelSettings?
  tokens            TwitchToken?
  commands          Command[]
  timers            Timer[]
  events            BotEvent[]
  logs              AuditLog[]
  chats             ChatMessage[]
  community         CommunityUser[]
  sessions          StreamSession[]
  recaps            StreamRecap[]
  campaigns         Campaign[]
  discord           DiscordIntegration?
  notes             ModerationNote[]
  actions           ModerationAction[]
  botStatusLinks    ChannelBotStatus[]
  twitchRoleActions TwitchRoleAction[]
}

model PlatformTwitchBot {
  id                    String             @id @default(cuid())
  twitchUserId          String             @unique
  twitchLogin           String
  displayName           String
  avatarUrl             String?
  accessTokenEncrypted  String
  refreshTokenEncrypted String
  scopesJson            String
  expiresAt             DateTime
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  isActive              Boolean            @default(true)
  channelStatus         ChannelBotStatus[]
}

model ChannelBotStatus {
  id            String            @id @default(cuid())
  channelId     String            @unique
  platformBotId String
  status        String            @default("unknown")
  isModerator   Boolean           @default(false)
  lastCheckedAt DateTime?
  lastError     String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  channel       Channel           @relation(fields: [channelId], references: [id], onDelete: Cascade)
  platformBot   PlatformTwitchBot @relation(fields: [platformBotId], references: [id], onDelete: Restrict)
}

model ChannelMember {
  id        String   @id @default(cuid())
  channelId String
  userId    String
  role      Role
  createdAt DateTime @default(now())
  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
}

model ChannelSettings {
  id            String   @id @default(cuid())
  channelId     String   @unique
  commandPrefix String   @default("!")
  language      String   @default("de")
  timezone      String   @default("Europe/Berlin")
  botEnabled    Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  channel       Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
}

model TwitchToken {
  id                    String   @id @default(cuid())
  channelId             String   @unique
  accessTokenEncrypted  String
  refreshTokenEncrypted String
  scopesJson            String
  expiresAt             DateTime
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  channel               Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
}

model Command {
  id              String   @id @default(cuid())
  channelId       String
  name            String
  aliasesJson     String
  response        String
  enabled         Boolean  @default(true)
  cooldownSeconds Int      @default(0)
  requiredRole    Role     @default(viewer)
  conditionsJson  String   @default("{}")
  usageCount      Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  channel         Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([channelId, name])
}

model Timer {
  id              String    @id @default(cuid())
  channelId       String
  name            String
  message         String
  intervalMinutes Int
  enabled         Boolean   @default(true)
  lastRunAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  channel         Channel   @relation(fields: [channelId], references: [id], onDelete: Cascade)
}

model BotEvent {
  id          String   @id @default(cuid())
  channelId   String?
  platform    Platform
  eventType   String
  payloadJson String
  createdAt   DateTime @default(now())
  channel     Channel? @relation(fields: [channelId], references: [id], onDelete: SetNull)
}

model AuditLog {
  id          String   @id @default(cuid())
  channelId   String?
  userId      String?
  action      String
  detailsJson String
  createdAt   DateTime @default(now())
  channel     Channel? @relation(fields: [channelId], references: [id], onDelete: SetNull)
  user        User?    @relation("AuditUser", fields: [userId], references: [id], onDelete: SetNull)
}

model ChatMessage {
  id                String   @id @default(cuid())
  channelId         String
  platform          Platform
  externalMessageId String?
  userExternalId    String
  username          String
  message           String
  createdAt         DateTime @default(now())
  channel           Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([channelId, platform, externalMessageId])
}

model CommunityUser {
  id              String   @id @default(cuid())
  channelId       String
  platform        Platform
  externalUserId  String
  username        String
  displayName     String?
  firstSeenAt     DateTime @default(now())
  lastSeenAt      DateTime @default(now())
  messageCount    Int      @default(0)
  commandCount    Int      @default(0)
  toxicityScore   Float?
  engagementScore Float?
  notes           String?
  channel         Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([channelId, platform, externalUserId])
}

model StreamSession {
  id                 String    @id @default(cuid())
  channelId          String
  title              String?
  category           String?
  startedAt          DateTime
  endedAt            DateTime?
  messageCount       Int       @default(0)
  uniqueChatterCount Int       @default(0)
  createdAt          DateTime  @default(now())
  channel            Channel   @relation(fields: [channelId], references: [id], onDelete: Cascade)
}

model StreamRecap {
  id                    String   @id @default(cuid())
  channelId             String
  streamSessionId       String?
  summary               String
  highlightsJson        String
  frequentQuestionsJson String
  suggestedCommandsJson String
  returningViewersJson  String
  engagementJson        String
  recommendationsJson   String
  createdAt             DateTime @default(now())
  channel               Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
}

model Campaign {
  id          String          @id @default(cuid())
  channelId   String
  name        String
  sponsorName String?
  targetUrl   String
  shortCode   String          @unique
  message     String
  enabled     Boolean         @default(true)
  startsAt    DateTime?
  endsAt      DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  channel     Channel         @relation(fields: [channelId], references: [id], onDelete: Cascade)
  clicks      CampaignClick[]
}

model CampaignClick {
  id             String   @id @default(cuid())
  campaignId     String
  platform       Platform
  userExternalId String?
  ipHash         String?
  userAgent      String?
  createdAt      DateTime @default(now())
  campaign       Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

model DiscordIntegration {
  id           String   @id @default(cuid())
  channelId    String   @unique
  guildId      String?
  guildName    String?
  botEnabled   Boolean  @default(false)
  settingsJson String   @default("{}")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  channel      Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
}

model ModerationNote {
  id              String   @id @default(cuid())
  channelId       String
  communityUserId String
  createdByUserId String?
  note            String
  createdAt       DateTime @default(now())
  channel         Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
}

model ModerationAction {
  id                   String   @id @default(cuid())
  channelId            String
  communityUserId      String?
  targetExternalUserId String?
  targetUsername       String?
  actionType           String
  durationSeconds      Int?
  reason               String?
  createdByUserId      String?
  createdAt            DateTime @default(now())
  channel              Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
}

model TwitchRoleAction {
  id                   String   @id @default(cuid())
  channelId            String
  targetExternalUserId String
  targetUsername       String?
  actionType           String
  roleType             String
  createdByUserId      String?
  createdAt            DateTime @default(now())
  channel              Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@index([channelId, createdAt])
}
